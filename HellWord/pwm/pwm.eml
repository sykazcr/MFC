CONFIG_PWM=3Dy
CONFIG_PWM_SYSFS=3Dy
# CONFIG_PWM_DEBUG is not set
# CONFIG_PWM_ATMEL_TCB is not set
# CONFIG_PWM_CLK is not set
# CONFIG_PWM_DWC is not set
# CONFIG_PWM_FSL_FTM is not set
# CONFIG_PWM_PCA9685 is not set
CONFIG_GPT_RZG2L=3Dy
CONFIG_POEG_RZG2L=3Dy
CONFIG_PWM_RCAR=3Dy
CONFIG_PWM_RENESAS_TPU=3Dy
CONFIG_PWM_RZ_MTU3=3Dy
# CONFIG_PWM_XILINX is not set

obj-$(CONFIG_PWM) +=3D core.o
obj-$(CONFIG_PWM_SYSFS) +=3D sysfs.o
obj-$(CONFIG_GPT_RZG2L) +=3D gpt-rzg2l.o

  gpt0_4: gpt@13010400 {
compatible =3D "renesas,gpt-r9a09g047";
reg =3D <0 0x13010000 0 0xa4>;
#pwm-cells =3D <2>;
interrupts =3D <GIC_SPI 542 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 550 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 558 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 566 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 574 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 582 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 590 IRQ_TYPE_EDGE_RISING>,
    <GIC_SPI 598 IRQ_TYPE_EDGE_RISING>;
interrupt-names =3D "gtcia", "gtcib", "gtcic",
 "gtcid", "gtcie", "gtcif",
 "gtcih", "gtcil";
clocks =3D <&cpg CPG_MOD 0x31>;
power-domains =3D <&cpg>;
resets =3D  <&cpg 0x59>,<&cpg 0x5A>;
status =3D "disabled";
};
static const struct of_device_id rzg2l_gpt_of_table[] =3D {
{ .compatible =3D "renesas,gpt-r9a07g044", .data =3D &rzg2l_cfg,},
{ .compatible =3D "renesas,gpt-r9a08g045", .data =3D &rzg2l_cfg,},
{ .compatible =3D "renesas,gpt-r9a09g057", .data =3D &rzv2h_cfg,},
{ .compatible =3D "renesas,gpt-r9a09g047", .data =3D &rzv2h_cfg,},
{ },
};
rzv2h-evk-common.dtsi(1247,1)  [SJIS]: &gpt0_2 {
&gpt0_2 {
pinctrl-0 =3D <&gpt0_2_pins>;
pinctrl-names =3D "default";
#if (GPT0_CHANNEL_SEL =3D=3D GPT_CHANNEL_A)
channel =3D "channel_A";
#elif (GPT0_CHANNEL_SEL =3D=3D GPT_CHANNEL_B)
channel =3D "channel_B";
#else
channel =3D "both_AB";
#endif
#if (I2C7_POEG_SEL)
poeg =3D <&poega0>;
#endif
status =3D "okay";
};
 gpt0_2_pins: gpt0_2 {
pinmux =3D <RZV2H_PORT_PINMUX(7, 2, 9)>, /* Channel A */
<RZV2H_PORT_PINMUX(7, 3, 9)>; /* Channel B */
};

You=E2=80=99re thinking in the right direction, but *you cannot create =E2=
=80=9C&gpt0_2_1=E2=80=9D
or multiple instances of the same GPT block*.
GPT hardware blocks are *fixed* in the SoC.
You can only enable the ones that physically exist.

But you *can* absolutely use *multiple pins* =E2=80=94 as long as they corr=
espond
to *different GPT channels*.

Let me explain this cleanly so you don=E2=80=99t waste time fighting the DT=
S.
------------------------------
=F0=9F=A7=A0 *1. You cannot create new GPT instances*

This is *wrong*:

&gpt0_2_1 {
    pinctrl-1 =3D <&gpt1_test_pins>;
};

Because:

   - gpt0_2 is a *hardware block*
   - It exists only once in the SoC
   - You cannot duplicate it in DTS

DTS overlays *configure hardware*, they do not create new hardware.
------------------------------
=F0=9F=A7=A0 *2. What you can do: enable multiple GPT channels*

Each GPT block has *two PWM channels*:
GPT instance Channel A Channel B
gpt0_0 pwm0 pwm1
gpt0_1 pwm0 pwm1
gpt0_2 pwm0 pwm1
gpt0_3 pwm0 pwm1
=E2=80=A6 =E2=80=A6 =E2=80=A6

If you need *6 PWM pins*, you must enable *3 GPT blocks*, each with 2
channels.

Example:

gpt0_0 =E2=86=92 2 pins
gpt0_1 =E2=86=92 2 pins
gpt0_2 =E2=86=92 2 pins
-----------------
Total =3D 6 PWM pins

------------------------------
=F0=9F=A7=A0 *3. How to enable multiple GPT blocks*

Example:

&gpt0_0 {
    pinctrl-0 =3D <&gpt0_0_pins>;
    channel =3D "both_AB";
    status =3D "okay";
};

&gpt0_1 {
    pinctrl-0 =3D <&gpt0_1_pins>;
    channel =3D "both_AB";
    status =3D "okay";
};

&gpt0_2 {
    pinctrl-0 =3D <&gpt0_2_pins>;
    channel =3D "both_AB";
    status =3D "okay";
};

This gives you *6 PWM outputs*.
------------------------------
=F0=9F=A7=A0 *4. You must create a pinctrl node for each GPT block*

Example:

gpt0_0_pins: gpt0_0_pins {
    pinmux =3D <RZV2H_PORT_PINMUX(7, 0, 9)>, /* Channel A */
             <RZV2H_PORT_PINMUX(7, 1, 9)>; /* Channel B */
};

gpt0_1_pins: gpt0_1_pins {
    pinmux =3D <RZV2H_PORT_PINMUX(7, 2, 9)>,
             <RZV2H_PORT_PINMUX(7, 3, 9)>;
};

gpt0_2_pins: gpt0_2_pins {
    pinmux =3D <RZV2H_PORT_PINMUX(7, 4, 9)>,
             <RZV2H_PORT_PINMUX(7, 5, 9)>;
};

You can name them anything:

   - gpt0_test_pins
   - sensor_pwm_pins
   - my_pwm_pins

The name is not important =E2=80=94 the *pinmux* is.
------------------------------
=F0=9F=A7=A0 *5. How Linux exposes them*

After boot:

/sys/class/pwm/pwmchip0 =E2=86=92 gpt0_0
/sys/class/pwm/pwmchip1 =E2=86=92 gpt0_1
/sys/class/pwm/pwmchip2 =E2=86=92 gpt0_2

Each pwmchip has 2 channels:

pwmchipX/pwm0 =E2=86=92 Channel A
pwmchipX/pwm1 =E2=86=92 Channel B

So with 3 GPT blocks:

pwmchip0/pwm0
pwmchip0/pwm1
pwmchip1/pwm0
pwmchip1/pwm1
pwmchip2/pwm0
pwmchip2/pwm1

That=E2=80=99s your 6 PWM pins.
------------------------------
=F0=9F=A7=A0 *6. Summary =E2=80=94 what you should do* =E2=9C=94=EF=B8=8F Y=
ou cannot create =E2=80=9Cgpt0_2_1=E2=80=9D

GPT blocks are fixed hardware.
=E2=9C=94=EF=B8=8F You *can* enable multiple GPT blocks

Each gives you 2 PWM outputs.
=E2=9C=94=EF=B8=8F You must create a pinctrl node for each block

Each pinctrl node defines the pins for A/B channels.
=E2=9C=94=EF=B8=8F You can generate PWM on all 6 pins via sysfs

Or via a consumer driver.
------------------------------

If you want, I can help you:

   - Pick the exact pins for your board
   - Write the DTS for all 6 PWM outputs
   - Verify which GPT blocks are free
   - Generate single=E2=80=91shot pulses for your sensor

Just tell me how many PWM pins you need and which physical pins you want to
use.

